# Copy to .env and fill in values. `.env` is gitignored.
# See https://github.com/oceanbase/powermem for the full config reference.

# --- Storage ---
DATABASE_PROVIDER=sqlite
SQLITE_PATH=./powermem.db

# --- LLM + embeddings (required at request time; server boots without them) ---
# Option A: Ollama locally (free). First:
#   ollama serve
#   ollama pull mistral && ollama pull nomic-embed-text
LLM_PROVIDER=ollama
LLM_MODEL=mistral
OLLAMA_LLM_BASE_URL=http://localhost:11434

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434

# Option B: OpenAI (swap the blocks above for these):
#LLM_PROVIDER=openai
#LLM_API_KEY=sk-...
#LLM_MODEL=gpt-4o-mini
#EMBEDDING_PROVIDER=openai
#EMBEDDING_API_KEY=sk-...
#EMBEDDING_MODEL=text-embedding-3-small

# --- Server ---
POWERMEM_SERVER_HOST=127.0.0.1
POWERMEM_SERVER_PORT=8000
POWERMEM_SERVER_AUTH_ENABLED=false
